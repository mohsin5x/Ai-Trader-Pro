# AI Trader Pro — Environment Variables
# Copy this file to .env and fill in your keys.
# The .env file is NEVER committed to git (see .gitignore).
# Keys set here override config.json settings.

# ── Data Provider ─────────────────────────────────────────────────────────
# Which provider to use by default: twelvedata | finnhub | alphavantage
DATA_PROVIDER=twelvedata

# Twelve Data (https://twelvedata.com) — recommended, 8 credits/min free
TWELVE_DATA_API_KEY=

# Finnhub (https://finnhub.io) — fallback
FINNHUB_API_KEY=

# Alpha Vantage (https://www.alphavantage.co) — fallback
ALPHA_VANTAGE_API_KEY=

# ── Rate Limits (override if on a paid plan) ──────────────────────────────
TWELVE_DATA_RATE_LIMIT=8
FINNHUB_RATE_LIMIT=30
ALPHA_VANTAGE_RATE_LIMIT=5

# ── Signal Engine ─────────────────────────────────────────────────────────
SIGNAL_MIN_CONFLUENCE=4
SIGNAL_MIN_CONFIDENCE=70
SIGNAL_SCAN_INTERVAL_SECONDS=90

# ── Watchlist ─────────────────────────────────────────────────────────────
WATCHLIST_REFRESH_SECONDS=15
WATCHLIST_MAX_SYMBOLS_PER_CYCLE=1
CHART_REFRESH_SECONDS=20
STALE_DATA_GRACE_SECONDS=320
NEWS_REFRESH_SECONDS=300

# ── Scanner ───────────────────────────────────────────────────────────────
# Minimum seconds between repeat notification alerts for the same symbol+direction.
# Prevents the same signal from triggering a new toast on every scan cycle.
SCANNER_NOTIFY_COOLDOWN_SECONDS=300
